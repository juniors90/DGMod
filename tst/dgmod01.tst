gap> LoadPackage("DGMod", "0", false);
true
gap> simples:= [];;
gap> S3 := SymmetricGroup(3);
Sym( [ 1 .. 3 ] )
gap> repsCC:=List(ConjugacyClasses(S3), Representative);
[ (), (1,2), (1,2,3) ]
gap> g := repsCC[3];
