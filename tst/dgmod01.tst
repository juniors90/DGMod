gap> S3_g := Centralizer( S3, g );
Group([ (1,2,3) ])
gap> irrepsS3_g := Irr( S3_g  );;
gap> for chi in irrepsS3_g do
> rho := IrreducibleAffordingRepresentation( chi );
> weight := rec( g := g, rho := rho );
> Add( simples, SimplesDGMod( S3, weight) );
> od;
