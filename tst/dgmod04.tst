gap> LoadPackage("DGMod", "0", false);
true
gap> G:=SymmetricGroup(3);
Sym( [ 1 .. 3 ] )
gap> repsCC:=List(ConjugacyClasses(G), Representative);
[ (), (1,2), (1,2,3) ]
gap> g:= repsCC[2];
