  [ 1, 1 ] ), Character( CharacterTable( Sym( [ 1 .. 2 ] ) ), [ 1, -1 ] ) ]
gap> chi := Irr( centralizer )[2];
Character( CharacterTable( Sym( [ 1 .. 2 ] ) ), [ 1, -1 ] )
gap> rho := IrreducibleAffordingRepresentation( chi );
[ (1,2) ] -> [ [ [ -1 ] ] ]
gap> TensorBasisForSimpleDGMod( G, g, rho );
[ ( () , [ 1 ] ), ( (1,3) , [ 1 ] ), ( (1,3,2) , [ 1 ] ) ]

